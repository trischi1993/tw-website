# build output
dist/
# dataset backups (provisioning safety exports - never commit)
/backups/
# generated types
.astro/
# wrangler local cache/state (Vorschau-Worker)
.wrangler/

# dependencies
node_modules/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# environment variables
.env
.env.production
# wrangler-Lokalsecrets (Konvention für `wrangler dev`)
.dev.vars

# macOS-specific files
.DS_Store

# jetbrains setting folder
.idea/

# sanity studio
studio/node_modules/
studio/dist/
studio/.sanity/

# Local-only work folders (add per project). Root-anchor any you add (leading /):
# macOS core.ignorecase=true makes an unanchored "Images/" also match
# src/assets/images/ and silently drop the site's tracked photos.
# Example:
# /client-briefing/
# /reference-sites/

# ShipStudio metadata
.shipstudio/
