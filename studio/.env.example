# Sanity Studio – Konfiguration.
# Diese Datei nach `.env` kopieren und die Projekt-ID eintragen.
# (`npx sanity init --env` legt die .env automatisch an.)

SANITY_STUDIO_PROJECT_ID=
SANITY_STUDIO_DATASET=production

# Ziel der Live-Vorschau (Presentation-Tool): lokal die Dev-Vorschau, deployt der
# Preview-Worker. Wird von sanity.config.ts gelesen; provision.mjs setzt es.
SANITY_STUDIO_PREVIEW_URL=http://localhost:4321
# SANITY_STUDIO_PREVIEW_URL=https://<preview-worker-url>   # deployed

# Sprache der Studio-Schema-Labels (Feld-Titel, Optionen): 'en' (Default) oder 'de'.
# Pro Kundenprojekt setzen, wenn die primäre Inhaltssprache Deutsch ist.
SANITY_STUDIO_UI_LOCALE=en
