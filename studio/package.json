{
  "name": "tristanweithaler-studio",
  "version": "1.0.0",
  "private": true,
  "description": "Sanity Studio for the upgreight Astro starter.",
  "type": "module",
  "scripts": {
    "dev": "sanity dev",
    "start": "sanity dev",
    "build": "sanity build",
    "deploy": "sanity deploy",
