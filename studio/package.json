    "import-seed": "npm run seed:build && sanity dataset import seed.ndjson production --replace"
  },
  "dependencies": {
    "@sanity/comlink": "4.0.1",
    "@sanity/icons": "5.0.0",
    "@sanity/vision": "6.4.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sanity": "6.4.0",
    "styled-components": "^6.4.3"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "typescript": "^5.9.3"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "fsevents@2.3.3": true
  }
}
