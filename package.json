{
  "name": "tristanweithaler",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.15.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "dev:preview": "astro dev --config astro.config.preview.mjs",
    "build:preview": "PREVIEW_DEPLOY=1 astro build --config astro.config.preview.mjs",
    "provision": "node scripts/provision.mjs",
    "postinstall": "patch-package --error-on-fail"
  },
  "imports": {
    "#sections-host": "./src/components/sections/SectionsHost.astro",
    "#preview-extras": "./src/components/PreviewExtras.astro"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.0.1",
    "@astrojs/react": "^6.0.1",
    "@astrojs/sitemap": "^3.7.3",
    "@sanity/client": "7.23.0",
    "@sanity/comlink": "4.0.1",
    "@sanity/image-url": "2.1.1",
    "@sanity/preview-url-secret": "4.0.8",
    "@sanity/visual-editing": "5.4.5",
    "astro": "^7.0.2",
    "gsap": "^3.15.0",
    "lenis": "^1.3.24",
    "patch-package": "^8.0.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.3"
  },
  "allowScripts": {
    "workerd@1.20260625.1": true,
    "esbuild@0.28.1": true,
    "fsevents@2.3.3": true,
    "sharp@0.34.5": true
  }
}
