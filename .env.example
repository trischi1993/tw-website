# --- Sanity (optional) -------------------------------------------------------
# Diese Variablen sind OPTIONAL. Solange sie fehlen, läuft die Website mit den
# eingebauten Seed-Inhalten (src/lib/content/). Erst wenn das Sanity Studio
# angebunden werden soll, diese Datei nach `.env` kopieren und ausfüllen –
# danach die Website neu bauen (`npm run build`). Siehe studio/README.md.

# PUBLIC_SANITY_PROJECT_ID=DEINE_PROJEKT_ID
# PUBLIC_SANITY_DATASET=production
# PUBLIC_SANITY_API_VERSION=2024-10-01

# --- Live-Vorschau (Stufe 2, NUR Vorschau-Umgebung) --------------------------
# Diese Variablen gehören ausschließlich in den Vorschau-Build/-Worker, NIEMALS
# in die Produktion. Sie aktivieren die Entwurfs-Vorschau (Drafts) im Studio.
#
# Lese-Token (Viewer-Scope) aus manage.sanity.io, Bereich API, Tokens:
# SANITY_API_READ_TOKEN=sk...
# Studio-URL (Click-to-edit-Ziele der Live-Island, data-sanity/createDataAttribute):
# SANITY_STUDIO_URL=https://<dein-studio>.sanity.studio
#
# Im STUDIO (studio/.env) zusätzlich, damit Presentation auf die Vorschau zeigt:
# SANITY_STUDIO_PREVIEW_URL=http://localhost:4321            # lokal
# SANITY_STUDIO_PREVIEW_URL=https://<vorschau-worker-url>    # deployed
