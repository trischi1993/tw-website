---
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
// In Produktion eine leere Komponente (No-op); nur der Vorschau-Build biegt
// diesen Subpath auf die Visual-Editing-Brücke um (History/Overlay/Refresh).
import PreviewExtras from '#preview-extras';
import { getSiteSettings } from '../lib/content';
import { HTML_LANG, UI } from '../lib/i18n';

interface Props {
  title: string;
  description: string;
  image?: string;
  noindex?: boolean;
  type?: 'website' | 'article';
  jsonLd?: Record<string, any> | Record<string, any>[];
  /** Header starts transparent with light text (for pages with a dark full-bleed hero). */
  transparentHeader?: boolean;
}
const {
  title,
  description,
  image,
  noindex,
  type,
  jsonLd,
  transparentHeader = false,
} = Astro.props;
const settings = await getSiteSettings();

// Organization auf jeder Seite: macht die Marke für Google/AI zur eindeutigen
// Entität. name/logo/url generisch aus den SiteSettings; sameAs nur, wenn echte
// Social-Profile gepflegt sind (sonst weglassen statt Platzhalter zu verlinken).
const sameAs = settings.social
  .map((s) => s.href)
  .filter((href) => /^https?:\/\//.test(href));
const orgJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: settings.siteName,
  url: Astro.site?.href,
  logo: Astro.site ? new URL('/apple-touch-icon.png', Astro.site).href : undefined,
  ...(sameAs.length ? { sameAs } : {}),
};
const pageJsonLd = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const jsonLdArray = [orgJsonLd, ...pageJsonLd];
---
<!doctype html>
<html lang={HTML_LANG}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#ffffff" />
    <meta name="color-scheme" content="light" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link
      rel="preload"
      href="/fonts/InstrumentSerif-Regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/hanken-grotesk-variable.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <SEO
      title={title}
      description={description}
      image={image}
      noindex={noindex}
      type={type}
      siteName={settings.siteName}
    />
    {
      jsonLdArray.map((data) => (
        // `<` maskieren, damit ein CMS-String mit „</script>" das Script nicht
        // vorzeitig schließt (JSON.stringify escaped `<` nicht). `<` bleibt
        // gültiges JSON.
        <script
          type="application/ld+json"
          is:inline
          set:html={JSON.stringify(data).replace(/</g, '\\u003c')}
        />
      ))
    }
    <slot name="head" />
  </head>
  <body>
    <a href="#main" class="skip-link">{UI.skipToContent}</a>
    <Header transparent={transparentHeader} />
    {/* tabindex=-1: macht das Sprung-Ziel per Skip-Link fokussierbar (sonst
        setzen manche Browser/AT den Fokus nicht zuverlässig auf <main>). */}
    <main id="main" tabindex="-1">
      <slot />
    </main>
    <Footer />
    <script>
      // GSAP/ScrollTrigger nur laden, wenn die Seite animierte Elemente hat.
      // Auf Seiten ohne Reveal/Parallax wird das Motion-Bundle nie geholt.
      if (document.querySelector('[data-reveal], [data-reveal-stagger], [data-parallax]')) {
        import('../scripts/motion.ts');
      }
    </script>
    <PreviewExtras />
  </body>
</html>
