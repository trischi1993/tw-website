---
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CtaModal from '../components/CtaModal.astro';
import AioModal from '../components/AioModal.astro';
// In Produktion eine leere Komponente (No-op); nur der Vorschau-Build biegt
// diesen Subpath auf die Visual-Editing-Brücke um (History/Overlay/Refresh).
import PreviewExtras from '#preview-extras';
import { getSiteSettings } from '../lib/content';
import { HTML_LANG, UI } from '../lib/i18n';

interface Props {
  title: string;
  description: string;
  image?: string;
  noindex?: boolean;
  type?: 'website' | 'article';
  jsonLd?: Record<string, any> | Record<string, any>[];
  /** Seiten-Slug als CSS-Haken auf <main> (z. B. seiten-spezifische Overrides). */
  route?: string;
}
const { title, description, image, noindex, type, jsonLd, route } = Astro.props;
const settings = await getSiteSettings();

// Organization auf jeder Seite: macht die Marke für Google/AI zur eindeutigen
// Entität. name/logo/url generisch aus den SiteSettings; sameAs nur, wenn echte
// Social-Profile gepflegt sind (sonst weglassen statt Platzhalter zu verlinken).
const sameAs = settings.social
  .map((s) => s.href)
  .filter((href) => /^https?:\/\//.test(href));
const orgJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: settings.siteName,
  url: Astro.site?.href,
  logo: Astro.site ? new URL('/apple-touch-icon.png', Astro.site).href : undefined,
  ...(sameAs.length ? { sameAs } : {}),
};
const pageJsonLd = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const jsonLdArray = [orgJsonLd, ...pageJsonLd];
---
<!doctype html>
<html lang={HTML_LANG}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      /* Pre-Paint-Motion-Flag: setzt html.has-motion VOR dem First Paint, damit
         die CSS-Ausgangszustände der Ladechoreo (global.css) schon im ersten
         Frame stehen und nichts aufblitzt (FOUC). Bei prefers-reduced-motion /
         ohne JS bleibt alles sichtbar. Failsafe: initialisiert das Motion-Bundle
         nicht (JS-Fehler), wird has-motion nach kurzer Frist entfernt → Inhalt
         sichtbar statt dauerhaft versteckt. */
      (function () {
        var el = document.documentElement;
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        el.classList.add('has-motion');
        window.addEventListener('load', function () {
          setTimeout(function () {
            if (!el.classList.contains('motion-ready')) el.classList.remove('has-motion');
          }, 1500);
        });
      })();
    </script>
    <meta name="theme-color" content="#0C0C0C" />
    <meta name="color-scheme" content="dark" />
    {/* Verbindung zum Sanity-Bild-CDN vorwaermen (DNS+TCP+TLS), damit das
        Hero-LCP-Bild ohne Handshake-Verzoegerung laedt. Ohne crossorigin, weil
        die <img>-Requests nicht als CORS laufen - sonst waere die vorgewaermte
        Verbindung nicht wiederverwendbar. */}
    <link rel="preconnect" href="https://cdn.sanity.io" />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link
      rel="preload"
      href="/fonts/poppins-light.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/poppins-regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <SEO
      title={title}
      description={description}
      image={image}
      noindex={noindex}
      type={type}
      siteName={settings.siteName}
    />
    {
      jsonLdArray.map((data) => (
        // `<` maskieren, damit ein CMS-String mit „</script>" das Script nicht
        // vorzeitig schließt (JSON.stringify escaped `<` nicht). `<` bleibt
        // gültiges JSON.
        <script
          type="application/ld+json"
          is:inline
          set:html={JSON.stringify(data).replace(/</g, '\\u003c')}
        />
      ))
    }
    <slot name="head" />
  </head>
  <body>
    <a href="#main" class="skip-link">{UI.skipToContent}</a>
    <Header />
    {/* tabindex=-1: macht das Sprung-Ziel per Skip-Link fokussierbar (sonst
        setzen manche Browser/AT den Fokus nicht zuverlässig auf <main>). */}
    <main id="main" tabindex="-1" data-route={route || undefined}>
      <slot />
    </main>
    <Footer />
    {/* Direkte Body-Kinder: die inert-Logik der Modals erwartet Top-Level. */}
    <CtaModal />
    <AioModal />
    <script>
      // Interaktive Widgets (FAQ, Tabs, Read-More, Load-More, Video-Controls)
      // laufen auf jeder Seite. Das GSAP-Motion-Bundle ebenso: Footer-Reveal,
      // Underline-Wipes und der Glow-CTA im Header animieren auf jeder Seite
      // (IX2 a-87/a-91/a-141); eine Hook-Bedingung wäre immer wahr.
      import('../scripts/widgets.ts');
      // Fragmentziele erst nach dem Motion-Setup nachjustieren: ScrollTrigger
      // erweitert auf der Startseite vor dem Ziel mehrere Scroll-Strecken.
      import('../scripts/motion.ts').then(() => import('../scripts/hash-navigation.ts'));
    </script>
    <PreviewExtras />
  </body>
</html>
