---
// Single source of <head> SEO. Canonical + absolute OG URLs derive from
// Astro.site, so they're always correct as long as `site` is set in the config.
import { OG_LOCALE } from '../lib/i18n';

interface Props {
  title: string;
  description: string;
  /** Page-specific OG image (absolute or site-relative). Omitted if not set. */
  image?: string;
  /** Override canonical (rarely needed). Defaults to this page's own URL. */
  canonical?: string;
  noindex?: boolean;
  type?: 'website' | 'article';
  /** Markenname (aus den SiteSettings). Treibt Title-Suffix + og:site_name. */
  siteName?: string;
}

// Fallback-Markenname, falls keine SiteSettings durchgereicht werden.
const FALLBACK_SITE_NAME = 'Tristan Weithaler';
// Standard-Share-Bild (1200×630), genutzt wenn eine Seite kein eigenes OG-Bild
// setzt – so ist nie eine Seite bildlos. Pro Projekt public/og-default.png ersetzen.
const DEFAULT_OG_IMAGE = '/og-default.png';

const {
  title,
  description,
  image,
  canonical,
  noindex = false,
  type = 'website',
  siteName = FALLBACK_SITE_NAME,
} = Astro.props;

const site = Astro.site;
const canonicalURL = canonical ?? new URL(Astro.url.pathname, site).href;
// Title-Vorlage „Seite | Marke“. Kein Suffix, wenn der Title die Marke schon
// enthält (Original-Titles wie „Tristan Weithaler - Über mich" blieben sonst
// doppelt gebrandet).
const fullTitle = title.includes(siteName) ? title : `${title} | ${siteName}`;
// Immer ein OG-Bild: seitenspezifisches, sonst das Default-Share-Bild.
const imageURL = new URL(image ?? DEFAULT_OG_IMAGE, site).href;
---

<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />
{noindex && <meta name="robots" content="noindex, nofollow" />}

{/* Open Graph */}
<meta property="og:type" content={type} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:image" content={imageURL} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:locale" content={OG_LOCALE} />
<meta property="og:site_name" content={siteName} />

{/* Twitter */}
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageURL} />
