---
import dolomites from '../assets/images/footer-dolomiten.avif';
import logoTw from '../assets/images/logo-tw.avif';
import emailIcon from '../assets/images/icon-email.svg';
import { getSiteSettings } from '../lib/content';
import { safeHref } from '../lib/safe-href';

/**
 * Footer (Webflow section_footer, global-chrome.md §6): Dolomiten-Band auf
 * #1D1D1D, Logo + Claim + Lottie-Socials links, Nav + E-Mail-Block rechts,
 * Legal-Zeile mit upgreight-Credit (Hausregel). Lottie-Icons laden lazy
 * (lottie-web light), spielen 1× beim Sichtbarwerden, Hover startet neu.
 */
const settings = await getSiteSettings();
const { contact } = settings;
const isExternal = (href: string) => /^https?:\/\//.test(href);

/** Label → Lottie-Datei + Größe (global-chrome.md §6). */
function lottieFor(label: string): { path: string; size: string } | null {
  const l = label.toLowerCase();
  if (l.includes('insta')) return { path: '/lottie/instagram.json', size: '2rem' };
  if (l.includes('linked')) return { path: '/lottie/linkedin.json', size: '1.75rem' };
  return null;
}

const footerNav = [{ label: 'Startseite', href: '/' }, ...settings.nav];
const mailHref = `mailto:${contact.email}?subject=Hey%20Tristan`;
---
<footer class="footer">
  <img
    class="footer__dolomites"
    src={dolomites.src}
    width={dolomites.width}
    height={dolomites.height}
    alt=""
    loading="lazy"
    decoding="async"
  />
  <div class="footer__body">
    <div class="container">
      <div class="footer__grid">
        <div class="footer__first">
          <a href="/" class="footer__logo-link" aria-label={`${settings.siteName}, zur Startseite`}>
            <img
              class="footer__logo"
              src={logoTw.src}
              width={logoTw.width}
              height={logoTw.height}
              alt=""
              loading="lazy"
              decoding="async"
            />
          </a>
          {settings.tagline && <p class="footer__claim">{settings.tagline}</p>}
          {
            settings.social.length > 0 && (
              <ul role="list" class="footer__social-list" data-lottie-root>
                {settings.social.map((s) => {
                  const lottie = lottieFor(s.label);
                  return (
                    <li>
                      <a
                        class="footer__social"
                        href={safeHref(s.href)}
                        target="_blank"
                        rel="noopener noreferrer"
                        aria-label={s.label}
                      >
                        {lottie ? (
                          <span
                            class="footer__social-icon"
                            data-lottie={lottie.path}
                            style={`width:${lottie.size};height:${lottie.size}`}
                            aria-hidden="true"
                          />
                        ) : (
                          s.label
                        )}
                      </a>
                    </li>
                  );
                })}
              </ul>
            )
          }
        </div>

        <div class="footer__second">
          <nav class="footer__nav" aria-label="Footer-Navigation">
            <ul role="list">
              {
                footerNav.map((item) => (
                  <li>
                    <a
                      class="footer__nav-link"
                      href={safeHref(item.href)}
                      target={isExternal(item.href) ? '_blank' : undefined}
                      rel={isExternal(item.href) ? 'noopener noreferrer' : undefined}
                    >
                      {item.label}
                    </a>
                  </li>
                ))
              }
            </ul>
          </nav>

          <div class="footer__contact">
            <img class="footer__contact-icon" src={emailIcon.src} alt="" width="28" height="28" loading="lazy" />
            <p class="footer__contact-title">Email</p>
            <a class="footer__mail" href={mailHref}>{contact.email}</a>
          </div>
        </div>
      </div>

      <div class="footer__legal">
        <p class="footer__legal-links">
          {
            settings.legalLinks.map((item, i) => (
              <>
                {i > 0 && <span aria-hidden="true"> • </span>}
                <a href={safeHref(item.href)}>{item.label}</a>
              </>
            ))
          }
        </p>
        <p class="footer__credit">
          Created by <a href="https://upgreight.com" target="_blank" rel="noopener noreferrer">upgreight</a>
        </p>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer { background: var(--paper); }
  .footer__dolomites { width: 100%; height: auto; display: block; }
  .footer__body { background: var(--paper-2); padding-block: 3rem 2rem; }

  .footer__grid {
    display: flex;
    justify-content: space-between;
    gap: 3rem;
  }
  .footer__first { width: 34%; }
  .footer__second {
    width: 55%;
    display: flex;
    justify-content: space-between;
    gap: 3rem;
  }

  .footer__logo-link { display: inline-block; line-height: 0; }
  .footer__logo { width: 9rem; height: auto; }
  .footer__claim {
    margin-top: 1.5rem;
    color: #d6d6d6;
    max-width: 24ch;
  }
  .footer__social-list {
    display: flex;
    align-items: center;
    gap: 2rem;
    margin-top: 2rem;
  }
  .footer__social {
    display: inline-flex;
    align-items: center;
    color: var(--ink);
  }
  .footer__social-icon { display: inline-block; }

  .footer__nav ul {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .footer__nav-link {
    color: var(--ink);
    font-size: 1.25rem;
    font-weight: 300;
  }
  .footer__nav-link:hover { color: var(--brand-cream); }

  .footer__contact-icon { width: 1.75rem; height: 1.75rem; }
  .footer__contact-title {
    margin-top: 0.75rem;
    color: var(--ink);
    font-size: 2.25rem;
    font-weight: 500;
    line-height: 1.1875;
  }
  .footer__mail {
    display: inline-block;
    margin-top: 0.5rem;
    color: var(--brand);
    font-size: 1.125rem;
  }
  .footer__mail:hover { color: var(--brand-cream); }

  .footer__legal {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.75rem 2rem;
    margin-top: 4rem;
    color: var(--ink-4);
    font-size: 0.825rem;
  }
  .footer__legal a { color: inherit; }
  .footer__legal a:hover { color: var(--ink-2); }

  @media (max-width: 991px) {
    .footer__grid { gap: 4rem; }
  }
  @media (max-width: 767px) {
    .footer__grid { flex-flow: column; }
    .footer__first, .footer__second { width: 100%; }
    .footer__second { flex-flow: column; }
  }
  @media (max-width: 479px) {
    .footer__contact-title { font-size: 2rem; }
  }
</style>

<script>
  // Lottie-Socials: erst beim Sichtbarwerden des Footers laden (lazy, light
  // build ohne Expressions), 1× abspielen, Hover startet die Animation neu.
  const root = document.querySelector<HTMLElement>('[data-lottie-root]');
  if (root) {
    const io = new IntersectionObserver(
      async (entries) => {
        if (!entries.some((e) => e.isIntersecting)) return;
        io.disconnect();
        const lottie = (await import('lottie-web/build/player/lottie_light')).default;
        root.querySelectorAll<HTMLElement>('[data-lottie]').forEach((el) => {
          const anim = lottie.loadAnimation({
            container: el,
            renderer: 'svg',
            loop: false,
            autoplay: true,
            path: el.dataset.lottie!,
          });
          el.closest('a')?.addEventListener('mouseenter', () => anim.goToAndPlay(0, true));
        });
      },
      { rootMargin: '200px' },
    );
    io.observe(root);
  }
</script>
