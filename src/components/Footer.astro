---
import dolomites from '../assets/images/footer-dolomiten.avif';
import logoTw from '../assets/images/logo-tw.avif';
import emailIcon from '../assets/images/icon-email.svg';
import { getSiteSettings } from '../lib/content';
import { safeHref } from '../lib/safe-href';

/**
 * Footer (Webflow section_footer, global-chrome.md §6): Dolomiten-Band auf
 * #1D1D1D, Logo + Claim + Lottie-Socials links, Nav + E-Mail-Block rechts,
 * Legal-Zeile mit upgreight-Credit (Hausregel). Lottie-Icons laden lazy
 * (lottie-web light), spielen 1× beim Sichtbarwerden (Webflow data-autoplay);
 * Hover spielt in 600 ms neu ab (IX2 a-78). Reveal-Choreo + Geschwister-Dim:
 * src/scripts/motion/footer.ts (IX2 a-87, a-123/a-124); die data-footer-*-
 * Hooks hier sind deren Anker. Overflow-Masken wie im Original:
 * .footer__first (Logo/Claim/Socials) und .footer__contact gesamt, je
 * Nav-Link ein eigener Mask-Wrapper (li).
 */
const settings = await getSiteSettings();
const { contact } = settings;
const isExternal = (href: string) => /^https?:\/\//.test(href);

/** Label → Lottie-Datei + Größe (global-chrome.md §6). */
function lottieFor(label: string): { path: string; size: string } | null {
  const l = label.toLowerCase();
  if (l.includes('insta')) return { path: '/lottie/instagram.json', size: '2rem' };
  if (l.includes('linked')) return { path: '/lottie/linkedin.json', size: '1.75rem' };
  return null;
}

const footerNav = [{ label: 'Startseite', href: '/' }, ...settings.nav];
const mailHref = `mailto:${contact.email}?subject=Hey%20Tristan`;
---
<footer class="footer">
  <img
    class="footer__dolomites"
    src={dolomites.src}
    width={dolomites.width}
    height={dolomites.height}
    alt=""
    loading="lazy"
    decoding="async"
  />
  <div class="footer__body" data-footer>
    <div class="container">
      <div class="footer__grid">
        <div class="footer__first">
          <a href="/" class="footer__logo-link" aria-label={`${settings.siteName}, zur Startseite`}>
            <img
              class="footer__logo"
              src={logoTw.src}
              width={logoTw.width}
              height={logoTw.height}
              alt=""
              loading="lazy"
              decoding="async"
              data-footer-logo
            />
          </a>
          {settings.tagline && <p class="footer__claim" data-footer-claim>{settings.tagline}</p>}
          {
            settings.social.length > 0 && (
              <ul role="list" class="footer__social-list" data-lottie-root data-dim-group>
                {settings.social.map((s) => {
                  const lottie = lottieFor(s.label);
                  return (
                    <li data-footer-social data-dim-item>
                      <a
                        class="footer__social"
                        href={safeHref(s.href)}
                        target="_blank"
                        rel="noopener noreferrer"
                        aria-label={s.label}
                      >
                        {lottie ? (
                          <span
                            class="footer__social-icon"
                            data-lottie={lottie.path}
                            style={`width:${lottie.size};height:${lottie.size}`}
                            aria-hidden="true"
                          />
                        ) : (
                          s.label
                        )}
                      </a>
                    </li>
                  );
                })}
              </ul>
            )
          }
        </div>

        {/* Rechte Spalte als 2×2-Grid (Spalte 1: Nav/Legal-Links links,
            Spalte 2: E-Mail/Credit rechts). So fluchtet „Created by upgreight"
            linksbündig unter die E-Mail-Spalte (gleicher Inset), und die
            Kontakt-Box wird nicht auf Nav-Höhe gestreckt (E-Mail-Maske clippt). */}
        <div class="footer__second">
          <nav class="footer__nav" aria-label="Footer-Navigation">
            <ul role="list" data-dim-group>
              {
                footerNav.map((item) => (
                  <li class="footer__nav-mask" data-dim-item>
                    <a
                      class="footer__nav-link"
                      href={safeHref(item.href)}
                      target={isExternal(item.href) ? '_blank' : undefined}
                      rel={isExternal(item.href) ? 'noopener noreferrer' : undefined}
                      data-footer-nav-link
                    >
                      {item.label}
                    </a>
                  </li>
                ))
              }
            </ul>
          </nav>

          <div class="footer__contact">
            <img
              class="footer__contact-icon"
              src={emailIcon.src}
              alt=""
              width="43"
              height="27"
              loading="lazy"
              data-footer-contact-icon
            />
            <p class="footer__contact-title" data-footer-contact-title>Email</p>
            <a class="footer__mail" href={mailHref} data-footer-mail>{contact.email}</a>
          </div>

          {/* Legal-Links unten links (unter der Nav), Credit unten rechts
              (linksbündig unter der E-Mail-Spalte). */}
          <p class="footer__legal-links" data-footer-legal>
            {
              settings.legalLinks.map((item, i) => (
                <>
                  {i > 0 && <span aria-hidden="true"> • </span>}
                  <a href={safeHref(item.href)}>{item.label}</a>
                </>
              ))
            }
          </p>
          <p class="footer__credit" data-footer-legal>
            Created by <a href="https://upgreight.com" target="_blank" rel="noopener noreferrer">upgreight</a>
          </p>
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  /* Werte 1:1 aus dem Export: section_footer (padding-top 3rem, @991 2rem),
     Dolomiten-Band, dann .background-color-secondary + .padding-global +
     .container-large + .padding-section-xxlarge (11rem, @991 10rem, @767 6rem). */
  .footer { background: var(--paper); padding-top: 3rem; }
  .footer__dolomites {
    width: 100%;
    height: auto;
    display: block;
    margin-bottom: -2px;
  }
  .footer__body { background: var(--paper-2); padding-block: 11rem; }

  .footer__grid {
    display: flex;
    justify-content: space-between;
  }
  /* Mask für Logo- (y -125 %), Claim- (x 5rem) und Social-Slides (y 130 %) —
     Original .footer_first-wrapper hat overflow: hidden. */
  .footer__first {
    width: 34%;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    overflow: hidden;
  }
  /* 2×2-Grid: Spalte 1 = Nav (oben) / Legal-Links (unten), Spalte 2 = E-Mail
     (oben) / Credit (unten). align-content: space-between hält oben/unten wie
     das frühere Flex-space-between; der Credit fluchtet dadurch linksbündig
     unter die E-Mail-Spalte (gleicher Inset). */
  .footer__second {
    width: 55%;
    display: grid;
    grid-template-columns: 1fr auto;
    align-content: space-between;
    row-gap: 2rem;
    column-gap: 2rem;
  }

  /* Logo wie im Original: 9rem mit Negativ-Margins (@991 6rem). */
  .footer__logo-link { display: inline-block; line-height: 0; margin-bottom: 1rem; }
  .footer__logo {
    width: 9rem;
    height: auto;
    margin-top: -1rem;
    margin-left: -0.5rem;
  }
  /* Feste Textbreite mit normalem, vorwärts füllendem Umbruch: So bleibt
     „Südtirols erster Social Media“ in Zeile 1 und „Business Coach“ in Zeile 2.
     `balance` würde beide Zeilen wieder auf ähnlich lange Wortgruppen verteilen
     und dadurch „Social Media“ trennen. */
  .footer__claim {
    color: #d6d6d6;
    inline-size: 16rem;
    max-inline-size: 100%;
    text-wrap: wrap;
  }
  .footer__social-list {
    display: flex;
    align-items: center;
    gap: 2rem;
    margin-top: 2rem;
  }
  .footer__social {
    display: inline-flex;
    align-items: center;
    color: var(--ink);
  }
  .footer__social-icon { display: inline-block; }

  .footer__nav ul {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
  }
  /* Mask je Link (Original: .overflow-hidden-Wrapper, Slide y -100 %).
     Kein CSS-Hover — der Original-Hover ist das Geschwister-Dimmen (a-123). */
  .footer__nav-mask { overflow: hidden; }
  .footer__nav-link {
    display: inline-block;
    color: var(--ink);
    font-size: 1.25rem;
    font-weight: 300;
  }

  /* Mask für den Mail-Slide (y 110 %) — Original .footer_contact-item;
     Innen ohne Abstände (Original stapelt icon/title/link direkt).
     align-self: start — NICHT auf Nav-Höhe strecken: sonst hätte die
     overflow:hidden-Maske unter der Mail Leerraum und der yPercent:110-Slide
     würde die Mail nicht verstecken (sie wäre von Anfang an sichtbar). */
  .footer__contact { overflow: hidden; margin-right: 2rem; align-self: start; }
  .footer__contact-icon { width: 2.6875rem; height: auto; }
  .footer__contact-title {
    color: var(--ink);
    font-size: 2.25rem;
    font-weight: 300;
  }
  .footer__mail {
    display: inline-block;
    /* Aufgehelltes Gold nur fuer diesen Link: --brand (#806429) erreicht auf
       --paper-2 nur 3,02:1; #aa8630 = 4,94:1 (WCAG AA). Globales Brand-Token
       bleibt unveraendert. */
    color: #aa8630;
  }

  /* Legal-Zeile unten (Grid-Reihe 2): Links links unter der Nav, Credit rechts
     linksbündig unter der E-Mail-Spalte. Text .825rem, gedämpft
     (Credit = Hausregel-Ergänzung). */
  .footer__legal-links,
  .footer__credit {
    color: var(--ink-4);
    font-size: 0.825rem;
  }
  .footer__legal-links a,
  .footer__credit a { color: inherit; }

  @media (max-width: 991px) {
    .footer { padding-top: 2rem; }
    .footer__body { padding-block: 10rem; }
    .footer__grid { gap: 4rem; }
    .footer__logo { width: 6rem; }
    .footer__second { flex: 1; column-gap: 3rem; }
    .footer__contact { margin-right: 0; }
  }
  @media (max-width: 767px) {
    .footer__body { padding-block: 6rem; }
    .footer__grid { flex-flow: column; gap: 3rem; }
    .footer__first { width: 100%; }
    /* Rechte Spalte einspaltig stapeln: Nav, E-Mail, Legal-Links, Credit. */
    .footer__second { grid-template-columns: 1fr; align-content: start; }
  }
  @media (max-width: 479px) {
    .footer__logo-link { margin-bottom: 2rem; }
    .footer__social-list { margin-top: 3.5rem; }
    .footer__second { width: 100%; }
    .footer__contact-title { font-size: 2rem; line-height: 1.2; }
    .footer__mail { overflow-wrap: anywhere; }
  }
</style>

<script>
  // Lottie-Socials: erst beim Sichtbarwerden des Footers laden (lazy, light
  // build ohne Expressions). Wie im Original: 1× Autoplay beim Laden (Webflow-
  // Embed data-autoplay="1"), Hover spielt von vorn in 600 ms bis zum Ende
  // (IX2 a-78: 0 → 99.8 % in 600 ms → Speed = Dauer / 0.6).
  // prefers-reduced-motion: kein Autoplay/Hover, stattdessen Endframe zeigen.
  // Jede [data-lottie-root]-Gruppe lazy laden (Footer + z. B. Über-mich-Hero
  // teilen dieselben Icons). lottie-web wird nur einmal ausgeliefert (der
  // dynamische Import ist gebündelt/gecacht) und pro Gruppe beim ersten
  // Sichtbarwerden initialisiert.
  const roots = document.querySelectorAll<HTMLElement>('[data-lottie-root]');
  if (roots.length) {
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const initRoot = async (root: HTMLElement) => {
      const lottie = (await import('lottie-web/build/player/lottie_light')).default;
      root.querySelectorAll<HTMLElement>('[data-lottie]').forEach((el) => {
        const anim = lottie.loadAnimation({
          container: el,
          renderer: 'svg',
          loop: false,
          autoplay: !reduceMotion,
          path: el.dataset.lottie!,
        });
        if (reduceMotion) {
          anim.addEventListener('DOMLoaded', () => {
            anim.goToAndStop(Math.max(0, anim.totalFrames - 1), true);
          });
          return;
        }
        el.closest('a')?.addEventListener('mouseenter', () => {
          anim.setSpeed(anim.getDuration(false) / 0.6);
          anim.goToAndPlay(0, true);
        });
      });
    };
    roots.forEach((root) => {
      const io = new IntersectionObserver(
        (entries) => {
          if (!entries.some((e) => e.isIntersecting)) return;
          io.disconnect();
          void initRoot(root);
        },
        { rootMargin: '200px' },
      );
      io.observe(root);
    });
  }
</script>
