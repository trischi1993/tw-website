---
import { getServices } from '../lib/content';

/**
 * Globales Anfrage-Modal (Webflow .cta-modal, global-chrome.md §8):
 * Formular mit bedingter Radio-Logik (Service-Typ → Unternehmens-Typ →
 * Choices.js-Multiselect aus der Coaching-Collection). Öffnen/Schließen,
 * Validierung und Submit: src/scripts/modals.ts. Formular-Ziel: Form.Taxi
 * (Endpunkt von Julian, 2026-07-21).
 */
const services = await getServices();
const dedupe = (values: string[]) => [...new Set(values.filter(Boolean))];
const personalOptions = dedupe(
  services.filter((s) => s.category === 'personal').map((s) => s.formName),
);
const businessOptions = dedupe(
  services.filter((s) => s.category === 'business').map((s) => s.formName),
);

const FORM_ACTION = 'https://form.taxi/s/vvg9bvd4';
---
<div class="modal" data-modal="cta" role="dialog" aria-modal="true" aria-labelledby="cta-modal-title" hidden>
  <div class="modal__overlay" aria-hidden="true"></div>
  <div class="modal__scroll" data-modal-backdrop>
    <div class="modal__container">
      <div class="modal__content">
        <button type="button" class="modal__close" data-modal-close aria-label="Schließen">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M12 4v16M4 12h16" />
          </svg>
        </button>
        <h2 class="modal__heading" id="cta-modal-title">Coaching anfragen</h2>

        <form
          class="modal__form"
          data-cta-form
          method="POST"
          action={FORM_ACTION}
          novalidate
        >
          <div class="modal__field">
            <label class="modal__label" for="cta-name">Name</label>
            <input
              class="modal-input"
              id="cta-name"
              name="Name"
              type="text"
              maxlength="256"
              placeholder="Max Mustermann"
              required
            />
          </div>
          <div class="modal__field">
            <label class="modal__label" for="cta-email">E-Mail-Adresse</label>
            <input
              class="modal-input"
              id="cta-email"
              name="E-Mail-Adresse"
              type="email"
              maxlength="256"
              placeholder="max@mustermann.com"
              required
            />
          </div>
          <div class="modal__field">
            <label class="modal__label" for="cta-job">Berufsbezeichnung oder Unternehmen</label>
            <input
              class="modal-input"
              id="cta-job"
              name="Berufsbezeichnung-Oder-Unternehmen"
              type="text"
              maxlength="256"
              placeholder="CEO bei Muster GmbH"
            />
          </div>
          <div class="modal__field">
            <label class="modal__label" for="cta-social">Social Media Link (falls vorhanden)</label>
            <input
              class="modal-input"
              id="cta-social"
              name="Social-Media-Link-falls-vorhanden"
              type="text"
              maxlength="256"
              placeholder="@Instagram…"
            />
          </div>

          <fieldset class="modal__field modal__radios" data-radio-group>
            <legend class="modal__label">Wähle deine gewünschte Coaching-Kategorie aus</legend>
            <div class="modal__radio-row">
              <label class="modal-radio">
                <input type="radio" name="Service-Typ" value="ALL-IN-ONE Coaching" data-target="isAIO" required />
                <span class="modal-radio__icon" aria-hidden="true"></span>
                <span class="modal-radio__text">ALL-IN-ONE Coaching</span>
              </label>
              <label class="modal-radio">
                <input type="radio" name="Service-Typ" value="Spezifische Coachings" data-target="isSpecificCoaching" required />
                <span class="modal-radio__icon" aria-hidden="true"></span>
                <span class="modal-radio__text">Spezifische Coachings</span>
              </label>
            </div>
          </fieldset>

          <div id="isSpecificCoaching" data-conditional hidden>
            <fieldset class="modal__field modal__radios" data-radio-group>
              <legend class="modal__label">Was trifft am besten auf dich zu?</legend>
              <div class="modal__radio-row">
                <label class="modal-radio">
                  <input type="radio" name="Unternehmens-Typ" value="Personal Brand / Selbstständig" data-target="isPersonalBrand" disabled />
                  <span class="modal-radio__icon" aria-hidden="true"></span>
                  <span class="modal-radio__text">Personal Brand / Selbstständig</span>
                </label>
                <label class="modal-radio">
                  <input type="radio" name="Unternehmens-Typ" value="Startup / Unternehmen" data-target="isUnternehmen" disabled />
                  <span class="modal-radio__icon" aria-hidden="true"></span>
                  <span class="modal-radio__text">Startup / Unternehmen</span>
                </label>
              </div>
            </fieldset>

            <div class="modal__field" id="isPersonalBrand" data-conditional hidden>
              <label class="modal__label" for="select-multiple-personal-brand">
                Welche Coaching-Bereiche interessieren dich?
              </label>
              <p class="modal__label-info">(Mehrfachauswahl möglich)</p>
              <select
                id="select-multiple-personal-brand"
                class="modal-select-multiple"
                multiple
                data-choices
                data-placeholder="Coaching-Bereiche wählen…"
              >
                {personalOptions.map((name) => <option value={name}>{name}</option>)}
              </select>
            </div>

            <div class="modal__field" id="isUnternehmen" data-conditional hidden>
              <label class="modal__label" for="select-multiple-unternehmen">
                Welche Coaching-Bereiche interessieren dich?
              </label>
              <p class="modal__label-info">(Mehrfachauswahl möglich)</p>
              <select
                id="select-multiple-unternehmen"
                class="modal-select-multiple"
                multiple
                data-choices
                data-placeholder="Coaching-Bereiche wählen…"
              >
                {businessOptions.map((name) => <option value={name}>{name}</option>)}
              </select>
            </div>
          </div>

          <input type="hidden" name="Coaching-Bereiche" data-choices-sync />

          <div class="modal__field">
            <label class="modal__label" for="cta-info">Weitere Informationen</label>
            <textarea
              class="modal-input is-text-area"
              id="cta-info"
              name="Weitere-Infos"
              maxlength="5000"
              placeholder="Erzähl mir gerne mehr von dir, deinem Projekt bzw. Unternehmen…"></textarea>
          </div>

          <div class="modal__field">
            <label class="modal-checkbox">
              <input type="checkbox" name="GDPR" required />
              <span class="modal-checkbox__box" aria-hidden="true">
                <svg viewBox="0 0 12 10" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path d="M1 5.5 4.2 8.5 11 1.5" />
                </svg>
              </span>
              <span>
                Ich akzeptiere die
                <a href="/datenschutz/" target="_blank" rel="noopener noreferrer">
                  Datenschutzerklärung
                </a>
              </span>
            </label>
          </div>

          <div class="modal__submit-row">
            <button type="submit" class="btn-glow" data-wait="Bitte warten..." data-glow>
              <span class="btn-glow__circle" aria-hidden="true" data-glow-circle=""></span>
              <span class="btn-glow__wrapper">
                <span class="btn-glow__content">
                  <span class="btn-glow__label" data-submit-label>Senden</span>
                </span>
              </span>
            </button>
          </div>
        </form>

        <div
          class="modal__success"
          data-form-success
          role="status"
          aria-live="polite"
          hidden
          tabindex="-1"
        >
          <h3>Vielen Dank!</h3>
          <p>
            Ich melde mich in Kürze bei dir. Bitte überprüfe auch deinen Spam-Ordner, falls meine
            Nachricht dort gelandet ist.
          </p>
        </div>
        <div
          class="modal__fail"
          data-form-fail
          role="alert"
          aria-live="assertive"
          hidden
          tabindex="-1"
        >
          <p>Ups! Etwas ist schief gelaufen - bitte versuche es nochmal.</p>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  /* --- Modal-Gerüst (global-chrome.md §8) ---------------------------------- */
  .modal {
    position: fixed;
    inset: 0;
    z-index: 610;
    -webkit-backdrop-filter: blur(1.5rem);
    backdrop-filter: blur(1.5rem);
    opacity: 0;
    transition: opacity 0.3s;
  }
  .modal.is-visible { opacity: 1; }
  .modal__overlay {
    position: fixed;
    inset: 0;
    z-index: 510;
    background: var(--overlay-modal);
  }
  .modal__scroll {
    position: fixed;
    inset: 0;
    z-index: 560;
    overflow: auto;
    /* Original: 10vh oben (Scroll-Container) + 10vh unten (padding-cta-modal) */
    padding: 10vh 5%;
  }
  .modal__container {
    max-width: 35rem;
    margin-inline: auto;
  }
  .modal__content {
    position: relative;
    background: var(--paper);
    border-radius: var(--radius-card);
    padding: 12% 10%;
    overflow: clip;
  }
  @media (max-width: 479px) {
    .modal__content { padding: 15% 5% 20%; }
  }
  .modal__close {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    display: grid;
    place-items: center;
    width: 2.25rem;
    height: 2.25rem;
    color: var(--ink);
    border-radius: 999rem;
    transform: rotate(45deg);
  }
  .modal__close svg { width: 1.5rem; height: 1.5rem; }
  @media (max-width: 767px) {
    .modal__close { top: 1rem; right: 1rem; }
  }
  .modal__heading {
    margin-bottom: 1.5rem;
    font-size: 2.5rem;
    font-weight: 700;
    line-height: 1.2;
  }
  @media (max-width: 991px) {
    .modal__heading { font-size: 1.75rem; }
  }
  @media (max-width: 767px) {
    .modal__heading { font-size: 1.5rem; line-height: 1.4; }
  }

  /* --- Felder --------------------------------------------------------------- */
  .modal__field { margin-top: 1.5rem; }
  .modal__label {
    display: block;
    margin-bottom: 0.5rem;
    font-weight: 400;
    color: var(--ink);
    padding: 0;
  }
  .modal__label-info {
    margin: 0 0 0.5rem;
    color: var(--ink-3);
    font-size: var(--text-sm);
  }
  /* .modal-input global (auch AioModal nutzt sie via eigener Kopie) */
  .modal-input {
    width: 100%;
    min-height: 2.75rem;
    padding: 0.5rem 0.75rem;
    background: var(--paper-2);
    border: 1px solid var(--form-line);
    border-radius: var(--radius-input);
    color: var(--ink);
    font-size: 16px;
    font-weight: 300;
  }
  .modal-input::placeholder { color: var(--ink-3); }
  .modal-input.is-text-area { min-height: 11.25rem; resize: vertical; }

  /* Radios als Pill-Buttons (Original .cta-radio-input/.quiz_radio-icon):
     die „Icon"-Fläche ist der absolute Pill-Hintergrund, checked = Goldrahmen. */
  .modal__radios {
    border: 0;
    margin: 1.5rem 0 0;
    padding: 0;
  }
  .modal__radio-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .modal-radio {
    position: relative;
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem 1rem;
    border-radius: var(--radius-input);
    cursor: pointer;
    color: var(--ink-3);
    font-size: 16px;
    text-align: center;
  }
  .modal-radio input {
    position: absolute;
    opacity: 0;
    width: 1px;
    height: 1px;
  }
  .modal-radio__icon {
    position: absolute;
    inset: 0;
    border: 1px solid var(--form-line);
    background: var(--paper-2);
    border-radius: var(--radius-input);
    transition: all 0.2s;
  }
  .modal-radio__text { position: relative; z-index: 1; }
  .modal-radio input:checked + .modal-radio__icon {
    border: 2px solid var(--brand);
  }
  .modal-radio input:focus-visible + .modal-radio__icon {
    border: 2px solid var(--brand);
    outline: 2px solid var(--brand);
    outline-offset: 3px;
  }
  @media (max-width: 479px) {
    .modal-radio { flex: 0 auto; }
  }

  .modal-checkbox {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    cursor: pointer;
    color: var(--ink-2);
    font-size: 16px;
    font-weight: 300;
  }
  .modal-checkbox input {
    position: absolute;
    opacity: 0;
    width: 1px;
    height: 1px;
  }
  .modal-checkbox__box {
    width: 1.125rem;
    height: 1.125rem;
    margin-top: 0.1rem;
    border: 1px solid var(--ink);
    border-radius: 0;
    flex: none;
    display: grid;
    place-items: center;
    color: transparent;
    transition: all 0.2s;
  }
  .modal-checkbox input:checked + .modal-checkbox__box {
    background: var(--brand);
    border-color: var(--brand);
    color: var(--ink);
  }
  .modal-checkbox input:focus-visible + .modal-checkbox__box {
    outline: 2px solid var(--brand);
    outline-offset: 3px;
  }
  .modal-checkbox__box svg { width: 0.7rem; height: 0.6rem; }
  /* Link wie Original: erbt die Textfarbe, nur unterstrichen + weight 400. */
  .modal-checkbox a {
    color: inherit;
    font-weight: 400;
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }

  .modal__submit-row {
    display: flex;
    justify-content: flex-end;
    margin-top: 2rem;
  }

  /* --- Erfolg / Fehler ------------------------------------------------------ */
  .modal__success { color: var(--ink); }
  .modal__success h3 { margin-bottom: 0.5rem; }
  .modal__success p { color: var(--ink-2); }
  .modal__fail {
    margin-top: 1.5rem;
    padding: 0.75rem 1rem;
    background: var(--error-bg);
    border-radius: var(--radius-input);
  }
  .modal__fail p { color: var(--error-fg); font-size: var(--text-sm); }
</style>

<style is:global>
  /* Inline-Fehlermeldungen (modals.ts) */
  .modal-field-error {
    margin-top: 0.4rem;
    color: var(--error-inline);
    font-size: 0.875rem;
  }

  /* Choices.js - 1:1-Port des Original-Embeds (.modal-select-multiple-css):
     Rahmen/BG liegen auf .choices, __inner ist transparent; Dropdown auf
     Seitengrund; Tags transparent mit Goldrahmen, Gold-Fläche bei Hover/
     Auswahl. Fokus ändert die Rahmenfarbe NICHT (wie Original).

     WICHTIG - jede Regel ist mit `.modal` gescoped: Choices' eigenes
     Stylesheet wird in modals.ts statisch importiert (Prod: von Astro mit ins
     HTML geinlined; dev: von Vite injiziert) - die Reihenfolge relativ zu
     diesem Block ist dabei nicht garantiert. Bei gleicher Spezifität gewänne
     ggf. das später geladene Default-CSS (Tags würden Choices-Türkis statt
     Gold). Der `.modal`-Präfix hebt die Spezifität über die Defaults -
     unabhängig von der Ladereihenfolge. */
  .modal .choices {
    width: 100%;
    margin-bottom: 0;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--form-line);
    border-radius: var(--radius-input);
    background: var(--paper-2);
    font-size: 16px;
    font-family: inherit;
  }
  .modal .choices__inner {
    display: inline-block;
    vertical-align: top;
    width: 100%;
    background: transparent;
    padding: 0;
    border: none;
    border-radius: 0;
    font-size: 16px;
    min-height: auto;
    overflow: hidden;
  }
  .modal .choices__inner::before { color: var(--ink-3); }
  .modal .choices.is-focused .choices__inner {
    border-color: var(--form-line);
    color: var(--ink);
  }
  .modal .choices__list--dropdown .choices__item--selectable {
    background: var(--paper-2);
    color: var(--ink-3);
    padding: 0.5rem;
  }
  .modal .choices__list--dropdown,
  .modal .choices__list[aria-expanded] {
    border-radius: var(--radius-input);
    background: var(--paper);
  }
  .modal .choices__list--dropdown .choices__item--selectable.is-highlighted,
  .modal .choices__list[aria-expanded] .choices__item--selectable.is-highlighted {
    background: var(--paper);
    color: var(--ink);
  }
  .modal .choices__input {
    width: 100%;
    padding: 0;
    border: 0;
    border-radius: 0;
    font-size: 16px;
    font-family: inherit;
    background: transparent;
    color: var(--ink);
    margin-bottom: 0;
  }
  .modal .choices__input::placeholder { color: var(--ink-3); }
  .modal .choices__list--multiple .choices__item {
    background: transparent;
    border: 1px solid var(--brand);
    border-radius: var(--radius-input);
    color: var(--ink);
  }
  .modal .choices__list--multiple .choices__item.is-selected,
  .modal .choices__list--multiple .choices__item:hover,
  .modal .choices__list--multiple .choices__item.is-highlighted {
    background: var(--brand);
    border-color: var(--brand);
    color: var(--ink);
  }
  .modal .choices[data-type*='select-multiple'] .choices__button {
    border-left: 1px solid var(--form-line);
    /* KEIN `filter: invert(1)`: das X des Multi-Select-Tags ist bei Choices
       11.2.3 per Default bereits weiß (--choices-icon-cross = #FFF, gedacht für
       den türkisen Default-Tag) und damit auf unserem dunklen Tag sichtbar.
       Ein invert würde es schwarz und damit unsichtbar machen. */
  }
</style>

<script>
  import '../scripts/modals.ts';
</script>
