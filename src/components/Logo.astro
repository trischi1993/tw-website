---
// Placeholder wordmark. Swap src/assets/brand/logo.svg for the real logo.
// Rendered as a plain <img> (SVGs scale without astro:assets transforms).
import logo from '../assets/brand/logo.svg';

interface Props {
  width?: number;
  class?: string;
  priority?: boolean;
  /** Accessible name. Usually empty: the surrounding link carries the label. */
  alt?: string;
}
const { width = 148, class: className, priority = false, alt = '' } = Astro.props;
const ratio = logo.height / logo.width;
const height = Math.round(width * ratio);
---
<img
  src={logo.src}
  alt={alt}
  width={width}
  height={height}
  loading={priority ? 'eager' : 'lazy'}
  decoding={priority ? 'sync' : 'async'}
  class={className}
/>
