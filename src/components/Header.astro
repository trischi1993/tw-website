---
import arrowWhite from '../assets/images/icon-arrow-white.svg';
import { getSiteSettings } from '../lib/content';
import { safeHref } from '../lib/safe-href';
import { UI as t } from '../lib/i18n';

/**
 * Fixe Navbar (Webflow .navbar, global-chrome.md §5): Blur-Hintergrund,
 * Split-Wortmarke mit Goldlinie, Desktop-Links mit Underline-Wipe, Glow-CTA
 * aus settings.headerCta, Burger ≤991px mit Fullscreen-Overlay-Menü (#121212).
 * Logik in src/scripts/menu.ts.
 */
const settings = await getSiteSettings();
const isExternal = (href: string) => /^https?:\/\//.test(href);

/** Fullscreen-Menü: Startseite + Hauptnavigation (global-chrome.md §5). */
const menuItems = [{ label: 'Startseite', href: '/' }, ...settings.nav];
---
<header class="navbar" data-site-header>
  <a href="/" class="navbar__logo" aria-label={`${settings.siteName}, ${t.toStart}`}>
    <span class="navbar__logo-split is-desktop" aria-hidden="true">
      <span class="navbar__logo-text">Tristan</span>
      <span class="navbar__logo-line"></span>
      <span class="navbar__logo-text">Weithaler</span>
    </span>
    <span class="navbar__logo-split is-mobile" aria-hidden="true">
      <span class="navbar__logo-text">T</span>
      <span class="navbar__logo-line is-gold-alt"></span>
      <span class="navbar__logo-text">W</span>
    </span>
  </a>

  <div class="navbar__right">
    <nav class="navbar__menu" aria-label={t.mainNav}>
      <ul role="list" class="navbar__list">
        {
          settings.nav.map((item) => (
            <li>
              <a
                href={safeHref(item.href)}
                class="navbar__link link-underline"
                target={isExternal(item.href) ? '_blank' : undefined}
                rel={isExternal(item.href) ? 'noopener noreferrer' : undefined}
              >
                {item.label}
                <span class="link-underline__line" aria-hidden="true"></span>
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    {
      settings.headerCta && (
        <a class="btn-glow navbar__cta" href={safeHref(settings.headerCta.href)} rel="nofollow">
          <span class="btn-glow__circle" aria-hidden="true" data-glow-circle="" />
          <span class="btn-glow__wrapper">
            <span class="btn-glow__content">
              <span class="btn-glow__label">{settings.headerCta.label}</span>
            </span>
          </span>
        </a>
      )
    }

    <button
      class="navbar__burger"
      type="button"
      aria-expanded="false"
      aria-controls="site-menu"
      data-nav-toggle
    >
      <span class="visually-hidden">{t.menu}</span>
      <span class="navbar__burger-line" aria-hidden="true"></span>
      <span class="navbar__burger-line" aria-hidden="true"></span>
      <span class="navbar__burger-line" aria-hidden="true"></span>
    </button>
  </div>
</header>

<div class="menu" id="site-menu" data-site-menu hidden>
  <nav class="menu__panel" aria-label={t.menu}>
    {
      menuItems.map((item) => (
        <a
          href={safeHref(item.href)}
          class="menu__link"
          target={isExternal(item.href) ? '_blank' : undefined}
          rel={isExternal(item.href) ? 'noopener noreferrer' : undefined}
        >
          <span class="menu__wipe" aria-hidden="true"></span>
          <span class="menu__text">{item.label}</span>
          <img class="menu__arrow" src={arrowWhite.src} alt="" width="36" height="36" loading="lazy" />
        </a>
      ))
    }
  </nav>
</div>

<style>
  /* --- Navbar (fix, Blur, dunkel-transluzent) ------------------------------ */
  .navbar {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 499;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    height: var(--header-h);
    padding: 0.125rem 5vw;
    background:
      linear-gradient(var(--overlay-navbar-tint), var(--overlay-navbar-tint)),
      var(--overlay-navbar);
    -webkit-backdrop-filter: blur(0.5rem);
    backdrop-filter: blur(0.5rem);
  }

  /* --- Split-Wortmarke ----------------------------------------------------- */
  .navbar__logo { display: inline-flex; align-items: center; text-decoration: none; }
  .navbar__logo-split { display: inline-flex; align-items: center; gap: 0.75rem; }
  .navbar__logo-text {
    color: var(--ink);
    font-size: 1.5rem;
    font-weight: 500;
    line-height: 1.1;
    white-space: nowrap;
  }
  .navbar__logo-line {
    width: 1.75px;
    height: 2rem;
    background: var(--brand);
    flex: none;
  }
  .navbar__logo-line.is-gold-alt { background: var(--logo-line); }
  .navbar__logo-split.is-mobile { display: none; }

  /* --- Desktop-Links ------------------------------------------------------- */
  .navbar__right { display: flex; align-items: center; gap: 1.5rem; }
  .navbar__list { display: flex; align-items: center; gap: 1.5rem; margin: 0; padding: 0; }
  .navbar__link {
    color: var(--ink-2);
    font-size: 1rem;
    font-weight: 300;
  }
  .navbar__link:hover { color: var(--ink); }

  /* --- Burger (≤991) ------------------------------------------------------- */
  .navbar__burger {
    display: none;
    position: relative;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.4375rem;
    width: 3rem;
    height: 3rem;
    background: var(--paper-2);
    border-radius: 100%;
    flex: none;
  }
  .navbar__burger-line {
    display: block;
    width: 1.25rem;
    height: 1.5px;
    background: var(--ink);
    transition: transform var(--dur-fast) var(--ease-smooth), opacity var(--dur-fast) var(--ease-smooth);
  }
  .navbar.is-menu-open .navbar__burger-line:nth-child(2) {
    transform: translateY(0.296875rem) rotate(45deg);
  }
  .navbar.is-menu-open .navbar__burger-line:nth-child(3) { opacity: 0; }
  .navbar.is-menu-open .navbar__burger-line:nth-child(4) {
    transform: translateY(-0.296875rem) rotate(-45deg);
  }

  /* --- Fullscreen-Menü (unter der Navbar, Panel #121212) ------------------- */
  .menu {
    position: fixed;
    inset: 0;
    z-index: 99;
    visibility: hidden;
    pointer-events: none;
    transition: visibility 0s 0.55s;
  }
  .menu.is-open {
    visibility: visible;
    pointer-events: auto;
    transition-delay: 0s;
  }
  .menu__panel {
    display: flex;
    flex-direction: column;
    width: 50%;
    height: 100%;
    margin-left: auto;
    padding-top: var(--header-h);
    background: var(--panel);
    transform: translateX(101%);
    transition: transform 0.55s var(--ease-smooth);
    overflow-y: auto;
  }
  .menu.is-open .menu__panel { transform: translateX(0); }

  .menu__link {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex: 1 1 0;
    min-height: 5.5rem;
    padding: 3.5rem;
    border-bottom: 1.5px solid var(--line-strong);
    text-decoration: none;
    overflow: hidden;
  }
  .menu__wipe {
    position: absolute;
    inset: auto 0 0 0;
    height: 0;
    background: var(--line-strong);
    transition: height 0.45s var(--ease-smooth);
    pointer-events: none;
  }
  .menu__link:hover .menu__wipe { height: 100%; }
  .menu__link:active .menu__wipe { background: var(--ink-3); }
  .menu__text {
    position: relative;
    color: var(--ink);
    font-size: var(--menu-link-size);
    font-weight: 300;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }
  .menu__arrow {
    position: relative;
    width: 2.25rem;
    height: 2.25rem;
    flex: none;
    transition: transform 0.45s var(--ease-smooth);
  }
  .menu__link:hover .menu__arrow { transform: translate(0.35rem, -0.35rem); }

  /* --- Breakpoints --------------------------------------------------------- */
  @media (max-width: 991px) {
    .navbar__menu { display: none; }
    .navbar__burger { display: inline-flex; }
    .menu__panel { width: 100%; }
    .menu__link { padding: 0 4.5rem; }
  }
  @media (max-width: 767px) {
    .navbar__logo-split.is-desktop { display: none; }
    .navbar__logo-split.is-mobile { display: inline-flex; }
    .menu__link { padding: 0 2rem; }
  }
</style>

<script>
  import '../scripts/menu.ts';
</script>
