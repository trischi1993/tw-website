---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import { UI } from '../lib/i18n';
---
<BaseLayout title={UI.notFoundMetaTitle} description={UI.notFoundMetaDescription} noindex={true}>
  <section class="section error-404">
    <div class="container error-404__inner">
      <h1 class="display-lg">{UI.notFoundTitle}</h1>
      <p class="lede">{UI.notFoundBody}</p>
      <div class="error-404__links">
        <a href="/" class="btn btn--primary">{UI.notFoundCta} <Icon name="arrow-right" /></a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .error-404 { padding-top: calc(var(--header-h) + clamp(4rem, 3rem + 6vw, 8rem)); }
  .error-404__inner { max-width: 44rem; display: flex; flex-direction: column; gap: var(--space-md); }
  .error-404__links { display: flex; flex-wrap: wrap; gap: var(--space-sm); margin-top: var(--space-md); }
</style>
