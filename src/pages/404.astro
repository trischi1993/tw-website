---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import { ui, DEFAULT_LOCALE } from '../lib/i18n';

// Statische Hosts liefern eine einzige 404-Seite, daher in der Default-Sprache.
const locale = DEFAULT_LOCALE;
const t = ui(locale);
---
<BaseLayout
  title={t.notFoundMetaTitle}
  description={t.notFoundMetaDescription}
  noindex={true}
  locale={locale}
>
  <section class="section error-404">
    <div class="container error-404__inner">
      <p class="eyebrow">{t.notFoundEyebrow}</p>
      <h1 class="display-lg">{t.notFoundTitle}</h1>
      <p class="lede">{t.notFoundBody}</p>
      <div class="error-404__links">
        <a href="/" class="btn btn--primary">{t.notFoundCta} <Icon name="arrow-right" /></a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .error-404 { padding-top: calc(var(--header-h) + clamp(4rem, 3rem + 6vw, 8rem)); }
  .error-404__inner { max-width: 44rem; display: flex; flex-direction: column; gap: var(--space-md); }
  .error-404__links { display: flex; flex-wrap: wrap; gap: var(--space-sm); margin-top: var(--space-md); }
</style>
