---
import BaseLayout from '../layouts/BaseLayout.astro';
// In Produktion der statische Host; nur der Vorschau-Build biegt diesen
// Subpath auf den Live-Island-Host um (package.json "imports" + Alias).
import SectionsHost from '#sections-host';
import { getHome, getSiteSettings } from '../lib/content';
import { ogImageUrl } from '../lib/content/images';
import { HTML_LANG } from '../lib/i18n';

const home = await getHome();
const settings = await getSiteSettings();

const sameAs = settings.social.map((s) => s.href).filter((href) => /^https?:\/\//.test(href));
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: settings.siteName,
    url: Astro.site?.href,
    inLanguage: HTML_LANG,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: settings.contact.ownerName,
    url: Astro.site?.href,
    jobTitle: settings.tagline,
    ...(sameAs.length ? { sameAs } : {}),
  },
];
---
<BaseLayout
  title={home.seo.title}
  description={home.seo.description}
  image={ogImageUrl(home.seo.image)}
  jsonLd={jsonLd}
>
  <SectionsHost sections={home.sections} document={{ id: home.documentId, type: 'homePage' }} />
</BaseLayout>
