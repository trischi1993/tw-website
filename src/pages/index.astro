---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
// In Produktion der statische Host; nur der Vorschau-Build biegt diesen
// Subpath auf den Live-Island-Host um (package.json "imports" + Alias).
import SectionsHost from '#sections-host';
import { getHome, getSiteSettings } from '../lib/content';
import { ogImageUrl } from '../lib/content/images';
import { homeAlternates, HTML_LANG } from '../lib/i18n';

// Deutsche Startseite (Default-Sprache, ohne Prefix unter /).
const locale = 'de' as const;
const home = await getHome(locale);
const settings = await getSiteSettings(locale);
const alternates = homeAlternates();

// Minimal, generic structured data. Extend per project as needed.
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: settings.siteName,
  url: Astro.site?.href,
  inLanguage: HTML_LANG[locale],
};
---
<BaseLayout
  title={home.seo.title}
  description={home.seo.description}
  image={ogImageUrl(home.seo.image)}
  locale={locale}
  alternates={alternates}
  jsonLd={jsonLd}
>
  <PageHeader title={settings.siteName} intro={settings.tagline} />
  <SectionsHost
    sections={home.sections}
    document={{ id: home.documentId, type: 'homePage' }}
    locale={locale}
  />
</BaseLayout>
